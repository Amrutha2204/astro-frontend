# Auth API base URL (e.g. auth-service)
# Use localhost when running auth-service locally, or a deployed/staging URL so other devs can run only the frontend.
NEXT_PUBLIC_API_URL=http://localhost:8001
 
# Astro / calculation API base URL (e.g. astro-service)
# Use localhost when running astro-service locally, or a deployed/staging URL to run the web app without running the backend.
NEXT_PUBLIC_ASTRO_API_URL=http://localhost:8002
